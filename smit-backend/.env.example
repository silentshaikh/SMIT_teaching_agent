# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# OpenAI Agents SDK
OPENAI_API_KEY=REPLACE_ME

# OpenRouter (LLM gateway)
OPENROUTER_API_KEY=REPLACE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# JWT auth
JWT_SECRET=REPLACE_ME

# File upload limits
MAX_FILE_SIZE_KB=50
ALLOWED_EXTENSIONS=.js,.py,.html

# CORS
ALLOWED_ORIGINS=*
